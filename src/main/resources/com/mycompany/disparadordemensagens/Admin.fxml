<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="750.0" prefWidth="1100.0" spacing="0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.disparadordemensagens.controller.AdminControle">
   <children>
      <HBox spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;" alignment="CENTER_LEFT">
         <children>
            <Label text="PAINEL DO ADMINISTRADOR" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="labelStatusSistema" text="● Sistema Online" style="-fx-text-fill: #27ae60;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Sair / Trocar Conta" onAction="#logout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
         </children>
      </HBox>

      <HBox VBox.vgrow="ALWAYS">
         <children>
            <VBox prefWidth="320.0" spacing="10" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 1 0 0;">
               <padding>
                  <Insets bottom="15" left="15" right="15" top="15" />
               </padding>
               <children>
                  <Label text="Selecionar Destinatários" style="-fx-font-weight: bold;" />
                  <TextField fx:id="campoPesquisa" promptText="🔍 Pesquisar usuário..." />
                  <ListView fx:id="listaUsuarios" VBox.vgrow="ALWAYS" />
                  <HBox spacing="5" alignment="CENTER">
                     <children>
                        <Button text="Selecionar Todos" onAction="#selecionarTodos" style="-fx-font-size: 11px;" />
                        <Button text="Desmarcar" onAction="#desmarcarTodos" style="-fx-font-size: 11px;" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white;">
               <padding>
                  <Insets bottom="20" left="25" right="25" top="15" />
               </padding>
               <children>
                  
                  <Label text="Histórico de Mensagens Enviadas (Log)" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                  <TextArea fx:id="logDeEnvios" editable="false" prefHeight="250.0" wrapText="true" 
                            promptText="As mensagens enviadas aparecerão aqui..."
                            style="-fx-control-inner-background: #fdfdfd; -fx-font-family: 'Consolas', 'Monospace'; -fx-font-size: 12px; -fx-border-color: #e0e0e0;" />

                  <Separator />

                  <Label text="Configurar Novo Disparo" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                  
                  <GridPane vgap="10" hgap="10">
                     <columnConstraints>
                        <ColumnConstraints prefWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                     </columnConstraints>
                     <children>
                        <Label text="Assunto:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="campoAssuntoAdmin" promptText="Assunto do comunicado oficial..." GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        
                        <Label text="Prioridade:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <ComboBox fx:id="comboPrioridade" prefWidth="180" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                     </children>
                  </GridPane>

                  <VBox spacing="5" VBox.vgrow="ALWAYS">
                     <children>
                        <Label text="Mensagem:" style="-fx-font-weight: bold;" />
                        <TextArea fx:id="campoMensagemAdmin" VBox.vgrow="ALWAYS" 
                                  promptText="Digite aqui o conteúdo que será disparado..." wrapText="true" />
                     </children>
                  </VBox>

                  <HBox spacing="15" alignment="CENTER_RIGHT">
                     <children>
                        <Label fx:id="labelContagem" text="0 usuários selecionados" style="-fx-text-fill: #7f8c8d;" />
                        <Button onAction="#limparAdmin" text="Limpar Campos" prefHeight="35" />
                        <Button onAction="#executarDisparoLote" text="EXECUTAR DISPARO" prefWidth="220" prefHeight="40"
                                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>