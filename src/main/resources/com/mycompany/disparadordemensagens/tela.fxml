<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" 
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.disparadordemensagens.controller.TelaControle"
            style="-fx-background-color: #1e1e1e;">
    <children>
        <!-- VBox principal ocupa toda a tela -->
        <VBox alignment="CENTER" spacing="15" 
              AnchorPane.topAnchor="0" 
              AnchorPane.bottomAnchor="0" 
              AnchorPane.leftAnchor="0" 
              AnchorPane.rightAnchor="0">

            <!-- Título -->
            <Text fill="#446ee1" text="Login">
                <font>
                    <Font name="Arial Black" size="28.0" />
                </font>
            </Text>

            <!-- Campo Nome -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Nome:" prefWidth="80" style="-fx-text-fill: #ecf0f1;"/>
                <TextField fx:id="nomelogin" promptText="Digite seu nome" prefWidth="220"
                           style="-fx-background-color: #2c2c2c; 
                                  -fx-text-fill: white; 
                                  -fx-prompt-text-fill: #888888; 
                                  -fx-background-radius: 12; 
                                  -fx-border-radius: 12; 
                                  -fx-border-color: #444444;" />
            </HBox>

            <!-- Campo Senha -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Senha:" prefWidth="80" style="-fx-text-fill: #ecf0f1;"/>
                <PasswordField fx:id="senhalogin" promptText="Digite sua senha" prefWidth="220"
                               style="-fx-background-color: #2c2c2c; 
                                      -fx-text-fill: white; 
                                      -fx-prompt-text-fill: #888888; 
                                      -fx-background-radius: 12; 
                                      -fx-border-radius: 12; 
                                      -fx-border-color: #444444;" />
            </HBox>

            <!-- Link de cadastro -->
            <Hyperlink fx:id="cadastrarNovoUsuario" onAction="#cadastrarNovoUsuario" 
                       text="Não possuo cadastro" style="-fx-text-fill: #bbbbbb;" />

            <!-- Botões -->
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="entrarLogin" text="Entrar" onAction="#entrarLogin"
                        style="-fx-background-color: linear-gradient(to bottom, #00aaff, #005f99); 
                               -fx-text-fill: white; 
                               -fx-background-radius: 20;" />
                <Button fx:id="limparLogin" text="Limpar" onAction="#limparLogin"
                        style="-fx-background-color: linear-gradient(to bottom, #ff5c5c, #b22222); 
                               -fx-text-fill: white; 
                               -fx-background-radius: 20;" />
            </HBox>

            <!-- Rodapé -->
            <VBox alignment="BOTTOM_CENTER" spacing="5"
                  AnchorPane.bottomAnchor="0.0"
                  AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0">
                <Label text="Desenvolvido por: Iuri"
                       style="-fx-text-fill: #bdc3c7; -fx-font-size: 12px; -fx-font-style: italic;" />
            </VBox>
        </VBox>
    </children>
</AnchorPane>
