<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.disparadordemensagens.controller.TelaControle">
    <children>
        <!-- VBox ocupa toda a tela e centraliza -->
        <VBox alignment="CENTER" spacing="15" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <!-- Título -->
            <Text fill="#446ee1" text="Login">
                <font>
                    <Font name="Arial Black" size="28.0" />
                </font>
            </Text>

            <!-- Campo Nome -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Nome:" prefWidth="80"/>
                <TextField fx:id="nomelogin" promptText="Digite seu nome" prefWidth="220" style="-fx-background-radius: 5; -fx-border-radius: 5;"/>
            </HBox>

            <!-- Campo Senha -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Senha:" prefWidth="80"/>
                <PasswordField fx:id="senhalogin" promptText="Digite sua senha" prefWidth="220" style="-fx-background-radius: 5; -fx-border-radius: 5;"/>
            </HBox>

            <!-- Link de cadastro -->
            <Hyperlink fx:id="cadastrarNovoUsuario" onAction="#cadastrarNovoUsuario" text="Não possuo cadastro" />

            <!-- Botões -->
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="entrarLogin" text="Entrar" onAction="#entrarLogin" style="-fx-background-color: #008afa; -fx-text-fill: white; -fx-background-radius: 5;"/>
                <Button fx:id="limparLogin" text="Limpar" onAction="#limparLogin" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
